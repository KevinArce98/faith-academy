generator client {
  provider      = "prisma-client"
  output        = "../src/lib/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum OrderStatus {
  PENDING_REVIEW
  ACTIVE
  EXPIRED
  REJECTED
  CANCELLED
}

enum AttendanceStatus {
  RESERVED
  ATTENDED
  CANCELLED
  NO_SHOW
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  MASTER
}

enum ContentType {
  VIDEO
  DOCUMENT
  IMAGE
}

model UserProfile {
  id            String   @id @default(cuid())
  email         String   @unique
  phone         String?
  name          String?
  avatarUrl     String?
  role          Role
  isActive      Boolean  @default(true)
  passwordHash  String
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())

  enrollmentFee Decimal?  @db.Decimal(10, 2)
  enrolledAt    DateTime?

  // Costo por hora del profesor: lo que la academia le paga por hora dada.
  hourlyRate Decimal? @db.Decimal(10, 2)

  subscriptions      MonthlySubscription[]
  monthlyAttendance  MonthlyAttendance[]
  sessionAttendances SessionAttendance[]

  orders             MembershipOrder[]
  enrollmentPayments EnrollmentPayment[]
  attendances  Attendance[]
  skills       UserSkill[]
  familyMember FamilyMember?
  emailTokens   EmailToken[]
  refreshTokens RefreshToken[]
  pushTokens    PushToken[]
  notifications Notification[]

  @@index([role])
  @@index([role, isActive])
}

// Token de push de Expo por dispositivo. Un usuario puede tener varios.
model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Notificación persistente (bandeja). Se crea al ocurrir un evento y, si el
// usuario tiene tokens, se envía además como push.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// Refresh tokens (sesiones) — se guarda solo el hash sha256; revocables y rotativos.
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model EmailToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  type      TokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model Family {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  members FamilyMember[]
}

model FamilyMember {
  id        String @id @default(cuid())
  familyId  String
  studentId String @unique
  position  Int

  family  Family      @relation(fields: [familyId], references: [id])
  student UserProfile @relation(fields: [studentId], references: [id])
}

model MembershipPlan {
  id          String  @id @default(cuid())
  name        String
  description String?
  price       Decimal @db.Decimal(10, 2)
  isActive    Boolean @default(true)

  classesPerWeek Int     @default(1)
  isPublic       Boolean @default(true)
  isSingleClass  Boolean @default(false)

  orders        MembershipOrder[]
  subscriptions MonthlySubscription[]
}

model MembershipOrder {
  id            String      @id @default(cuid())
  studentId     String
  planId        String
  status        OrderStatus @default(PENDING_REVIEW)
  receiptUrl    String?
  startsAt      DateTime?
  expiresAt     DateTime?
  approvedById  String?
  approvedAt    DateTime?
  notes         String?
  // Reserva de clase suelta: el alumno elige clase + fecha al pagar.
  bookingClassId String?
  bookingDate    DateTime? @db.Date
  createdAt     DateTime    @default(now())

  student        UserProfile    @relation(fields: [studentId], references: [id])
  plan           MembershipPlan @relation(fields: [planId], references: [id])
  bookingClass   Class?         @relation("OrderBookingClass", fields: [bookingClassId], references: [id])

  @@index([studentId])
  @@index([status])
  @@index([expiresAt])
  @@index([studentId, status])
}

// Pago de matrícula (anual, por aniversario). El alumno sube comprobante y el
// admin aprueba (o el admin la marca pagada a mano, sin receipt). Vale 1 año
// desde la aprobación: al día si hay uno ACTIVE con expiresAt > now.
model EnrollmentPayment {
  id           String      @id @default(cuid())
  studentId    String
  amount       Decimal     @db.Decimal(10, 2) // snapshot del enrollmentFee al pagar
  status       OrderStatus @default(PENDING_REVIEW)
  receiptUrl   String? // null cuando el admin la marca a mano
  startsAt     DateTime?
  expiresAt    DateTime?
  approvedById String?
  approvedAt   DateTime?
  notes        String?
  createdAt    DateTime    @default(now())

  student UserProfile @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([status])
  @@index([studentId, status])
}

model Class {
  id                String     @id @default(cuid())
  teacherId         String
  name              String
  description       String?
  skillLevel        SkillLevel
  maxCapacity       Int        @default(0)
  isPrivate         Boolean    @default(false) // compañía/audición: solo el admin inscribe; oculta para alumnos no asignados
  oneOffDate        DateTime?  @db.Date // clase única: ocurre una sola vez en esta fecha (la hora va en el único slot). null = recurrente semanal
  startsAt          DateTime // placeholder (modelo viejo); el horario real está en `slots`
  endsAt            DateTime
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())

  slots              ClassSlot[]
  attendances        Attendance[]
  monthlyAttendance  MonthlyAttendance[]
  sessionAttendances SessionAttendance[]
  content            Content[]
  bookingOrders      MembershipOrder[]   @relation("OrderBookingClass")
}

// Horario de una clase: un slot por día de la semana, con su hora propia.
model ClassSlot {
  id        String @id @default(cuid())
  classId   String
  dayOfWeek Int // 1 = Lunes … 7 = Domingo
  startTime String // "HH:mm" (hora del día)
  endTime   String // "HH:mm"

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([classId])
}

model Attendance {
  id             String           @id @default(cuid())
  classId        String
  studentId      String
  status         AttendanceStatus @default(RESERVED)
  qrToken        String?          @unique
  checkedAt      DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime         @default(now())

  class   Class       @relation(fields: [classId], references: [id])
  student UserProfile @relation(fields: [studentId], references: [id])

  @@index([classId])
  @@index([studentId])
  @@index([classId, status])
}

model UserSkill {
  id         String     @id @default(cuid())
  studentId  String
  skillLevel SkillLevel
  discipline String
  updatedAt  DateTime   @updatedAt

  student UserProfile @relation(fields: [studentId], references: [id])
}

model Content {
  id          String      @id @default(cuid())
  classId     String?
  title       String
  description String?
  type        ContentType
  url         String
  createdAt   DateTime    @default(now())

  class Class? @relation(fields: [classId], references: [id])
}

model MonthlySubscription {
  id        String    @id @default(cuid())
  studentId String
  planId    String
  period    DateTime
  amount    Decimal   @db.Decimal(10, 2)
  isPaid    Boolean   @default(false)
  paidAt    DateTime?
  expiresAt DateTime? // mensual: vence el día equivalente del mes siguiente; clase suelta: fin del día de la sesión elegida
  createdAt DateTime  @default(now())

  student UserProfile    @relation(fields: [studentId], references: [id])
  plan    MembershipPlan @relation(fields: [planId], references: [id])

  @@unique([studentId, period])
  @@index([period])
  @@index([studentId])
  @@index([studentId, isPaid, expiresAt])
}

model MonthlyAttendance {
  id        String    @id @default(cuid())
  studentId String
  classId   String
  period    DateTime
  sessionDate DateTime? @db.Date // clase suelta: solo vale esa fecha; null = mensual (todas las sesiones)
  createdAt DateTime  @default(now())

  student UserProfile @relation(fields: [studentId], references: [id])
  class   Class       @relation(fields: [classId], references: [id])

  @@unique([studentId, classId, period])
  @@index([classId, period])
  @@index([period])
}

// Asistencia REAL del día: el profe pasa lista por fecha. Es solo registro
// operativo — NO afecta el pago (eso sale de la inscripción / MonthlyAttendance).
model SessionAttendance {
  id        String   @id @default(cuid())
  classId   String
  studentId String
  date      DateTime @db.Date // día de la sesión
  createdAt DateTime @default(now())

  class   Class       @relation(fields: [classId], references: [id])
  student UserProfile @relation(fields: [studentId], references: [id])

  @@unique([classId, studentId, date])
  @@index([classId, date])
}
